# ── Supabase ─────────────────────────────────────────────
# Project URL + keys from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. NEVER expose to the browser. Used for admin/migrations/webhooks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App session (server-only signing secret) ───────────
SESSION_SECRET=generate-a-long-random-string-here
APP_URL=https://resumetrakr.com
# Optional comma-separated platform admin emails (defaults to nickperez@gmail.com)
ADMIN_EMAILS=nickperez@gmail.com

# ── LLM (server-side only) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model used for high-quality tasks (tailor, debrief, resume assist, parse).
AI_MODEL=claude-sonnet-4-5
# Faster/cheaper model for cover letters, Q&A, job parse, and prep drafts.
AI_MODEL_FAST=claude-haiku-4-5
AI_MAX_TOKENS=4096
# Fair-use: max AI API calls per user per month (each complete() = 1 action).
AI_PRO_MONTHLY_CAP=100
# Log a cost alert when estimated monthly API spend per user exceeds this (USD).
AI_COST_ALERT_USD=8
# Set true at GA to enforce Student/Standard tier limits (pilot defaults to Pro access).
AI_ENFORCE_PLAN_TIERS=false

# ── App ──────────────────────────────────────────────────
# Public base URL of the deployed app (for links, legacy env compat)
NEXT_PUBLIC_SITE_URL=https://resumetrakr.com
# Railway injects PORT automatically; Next reads it. Local default below.
PORT=3000
